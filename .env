# 1. Токен бота (получить у @BotFather в Telegram)
BOT_TOKEN=8711818859:AAGPHDLBOHHze_D0M-3wTdHZeaUhcDrVJdA

# 2. Ваш Telegram ID (узнать у @userinfobot)
#    Если несколько админов — через запятую: 123,456,789
